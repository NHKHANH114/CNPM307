<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical"
    android:padding="@dimen/define_dimen_5"
    tools:ignore="ContentDescription, UseCompoundDrawables">

    <RelativeLayout
        android:background="@drawable/bg_white_corner_6_border_gray"
        android:layout_width="match_parent"
        android:layout_gravity="center"
        android:gravity="center"
        android:backgroundTint="#F6EAD8"
        android:layout_height="wrap_content">

        <ImageView
            android:layout_marginTop="@dimen/define_dimen_10"
            android:layout_marginStart="@dimen/define_dimen_10"
            android:id="@+id/img_avatar"
            android:layout_width="@dimen/define_dimen_56"
            android:layout_height="@dimen/define_dimen_56"
            android:src="@drawable/ic_avatar_default" />

        <TextView

            android:id="@+id/tv_email"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/define_dimen_5"
            android:layout_below="@id/img_avatar"
            android:layout_marginStart="10dp"
            android:textSize="@dimen/text_size_normal"
            android:textStyle="italic" />
    </RelativeLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="@dimen/define_dimen_20"
        android:weightSum="2">

        <LinearLayout
            android:id="@+id/layout_report"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="@dimen/define_dimen_10"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/define_dimen_20"
            android:background="@drawable/bg_white_corner_6_border_gray"
            android:padding="@dimen/define_dimen_30"
            android:paddingBottom="@dimen/define_dimen_10"
            tools:ignore="InefficientWeight">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_report" />

            <TextView
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/report"
                android:layout_marginStart="@dimen/define_dimen_10"
                android:textColor="@color/textColorPrimary"
                android:textSize="@dimen/text_size_small" />
        </LinearLayout>


        <LinearLayout
            android:id="@+id/layout_feedback"
            android:layout_weight="1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="@dimen/define_dimen_10"
            android:background="@drawable/bg_white_corner_6_border_gray"
            android:padding="@dimen/define_dimen_30"
            android:paddingBottom="@dimen/define_dimen_10">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_feedback" />

            <TextView
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/feedback"
                android:layout_marginStart="@dimen/define_dimen_10"
                android:textColor="@color/textColorPrimary"
                android:textSize="@dimen/text_size_small" />
        </LinearLayout>
    </LinearLayout>



    <LinearLayout
        android:layout_marginTop="@dimen/define_dimen_10"
        android:id="@+id/layout_change_password"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="@dimen/define_dimen_10"

        android:paddingBottom="@dimen/define_dimen_10"
        android:background="@drawable/bg_white_corner_6_border_gray">

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/define_dimen_5"
            android:src="@drawable/ic_change_password" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/change_password"
            android:textStyle="bold"
            android:layout_marginStart="@dimen/define_dimen_10"
            android:textColor="@color/textColorPrimary"
            android:textSize="@dimen/text_size_small" />
    </LinearLayout>



    <LinearLayout
        android:id="@+id/layout_sign_out"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="@dimen/define_dimen_10"
        android:background="@drawable/bg_white_corner_6_border_gray"
        android:paddingTop="@dimen/define_dimen_10"
        android:paddingBottom="@dimen/define_dimen_10">

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/define_dimen_5"
            android:src="@drawable/ic_sign_out" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sign_out"
            android:textStyle="bold"
            android:layout_marginStart="@dimen/define_dimen_10"
            android:textColor="@color/textColorPrimary"
            android:textSize="@dimen/text_size_small" />
    </LinearLayout>

</LinearLayout>