<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:id="@+id/layoutItem"
    app:cardCornerRadius="@dimen/define_dimen_16"
    android:layout_marginEnd="@dimen/define_dimen_4"
    android:layout_marginBottom="@dimen/define_dimen_2"
    android:layout_marginTop="@dimen/define_dimen_8"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">


        <ImageView
            android:id="@+id/img_drink"
            android:src="@drawable/image_drink_example"
            android:layout_width="0dp"
            android:layout_height="@dimen/define_dimen_150"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>


        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/img_drink">

            <LinearLayout
                android:layout_marginStart="@dimen/define_dimen_8"
                android:id="@+id/layout_rate"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"

                >

                <TextView
                    android:id="@+id/tv_rate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    android:text="4.9"
                    android:paddingEnd="@dimen/define_dimen_5"
                    android:textSize="@dimen/text_size_small" />

                <ImageView
                    android:id="@+id/img_rate"
                    android:layout_width="@dimen/define_dimen_10"
                    android:layout_height="@dimen/define_dimen_10"
                    android:layout_marginTop="@dimen/define_dimen_5"
                    android:src="@drawable/ic_star_yellow"
                    tools:ignore="RtlSymmetry" />

            </LinearLayout>

            <ImageView
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="@dimen/define_dimen_5"
                android:layout_marginEnd="@dimen/define_dimen_5"
                android:layout_marginBottom="@dimen/define_dimen_5"
                android:layout_width="@dimen/define_dimen_20"
                android:layout_height="@dimen/define_dimen_20"
                android:src="@drawable/plus_circle"/>
            <TextView
                android:id="@+id/tv_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textStyle="bold"
                android:textColor="@color/colorPrimaryDark"
                android:textSize="@dimen/text_size_normal"
                android:layout_marginStart="@dimen/define_dimen_8"
                android:layout_marginEnd="@dimen/define_dimen_8"
                android:layout_marginTop="@dimen/define_dimen_8"
                app:layout_constraintTop_toBottomOf="@id/layout_rate"
                app:layout_constraintStart_toStartOf="parent"
                />

            <TextView
                android:id="@+id/tv_price_sale"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textColor="@color/textColorHeading"
                android:textSize="@dimen/text_size_small"
                android:textStyle="bold"
                android:layout_marginStart="@dimen/define_dimen_8"
                android:layout_marginEnd="@dimen/define_dimen_8"
                android:layout_marginTop="@dimen/define_dimen_8"
                app:layout_constraintTop_toBottomOf="@id/tv_name"
                app:layout_constraintStart_toStartOf="parent"
                />
            <TextView
                android:id="@+id/tv_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="visible"
                android:text=""
                android:textColor="@color/textColorSecondary"
                android:textSize="@dimen/text_size_xsmall"
                android:layout_marginStart="@dimen/define_dimen_8"
                android:layout_marginEnd="@dimen/define_dimen_8"
                android:layout_marginTop="@dimen/define_dimen_8"
                app:layout_constraintTop_toBottomOf="@id/tv_price_sale"
                app:layout_constraintStart_toStartOf="parent"/>


        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/tv_sale_off"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/red"
            android:padding="@dimen/define_dimen_2"
            android:layout_marginBottom="@dimen/define_dimen_8"
            android:layout_marginStart="@dimen/define_dimen_8"
            app:layout_constraintStart_toStartOf="@id/img_drink"
            app:layout_constraintBottom_toBottomOf="@id/img_drink"
            android:textColor="@color/white"
            android:textSize="@dimen/text_size_xxsmall"
            android:textStyle="bold"
            />


    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>