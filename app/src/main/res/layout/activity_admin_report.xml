<!--            android:layout_centerVertical="true"-->
<!--            android:textColor="@color/colorPrimaryDark"-->
<!--            android:textSize="@dimen/text_size_normal"-->
<!--            android:text="0 000 VNĐ"-->
<!--            android:textStyle="bold" />-->
    </RelativeLayout>

</RelativeLayout>